#!/bin/sh

blocked_patterns='(^|/)\.env$|(^|/)\.env\..+$|(^|/)\.evn$|(^|/)\.evn\..+$'
zero_sha='0000000000000000000000000000000000000000'
found_blocked=''

while read local_ref local_sha remote_ref remote_sha
do
  if [ "$local_sha" = "$zero_sha" ]; then
    continue
  fi

  if [ "$remote_sha" = "$zero_sha" ]; then
    commit_range=$(git rev-list "$local_sha" --not --all)
    if [ -z "$commit_range" ]; then
      commit_range=$local_sha
    fi
  else
    commit_range=$(git rev-list "$remote_sha..$local_sha")
  fi

  if [ -z "$commit_range" ]; then
    continue
  fi

  blocked_files=$(
    for commit in $commit_range
    do
      git diff-tree --no-commit-id --name-only -r "$commit"
    done | grep -E "$blocked_patterns" | sort -u
  )

  if [ -n "$blocked_files" ]; then
    found_blocked=$(printf '%s\n%s\n' "$found_blocked" "$blocked_files" | grep -v '^$' | sort -u)
  fi
done

if [ -n "$found_blocked" ]; then
  echo "Push blocked: secret env files are included in commits being pushed."
  echo "$found_blocked"
  echo "Remove them from the branch history or push a branch without those files."
  exit 1
fi

exit 0
